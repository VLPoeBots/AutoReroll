{
  "name": "AutoReroll",
  "version": "6.0.0",
  "description": "Automatically rerolls items",
  "main": "main.js",
  "type": "module",
  
  "build": {
    
    "asar": true,
    "publish": {
      "provider": "github",
      "owner": "VLFrosttide",
      "repo": "AutoReroll"
    },
    "asarUnpack": "renderer/SaveIconPics",
    "appId": "AutoReroll",  
    "extraFiles": [
      {"from": "MapsRoll.py",
       "to": "MapsRoll.py"
      },
      {"from": "AlchScour.py",
       "to": "AlchScour.py"
      },
      {
        "from": "python/Reroll.py",
        "to": "python/Reroll.py"
      },
      {
        "from": "python/HarvestReroll.py",
        "to": "python/HarvestReroll.py"
      },
      {
        "from": "python/UseCurrency.py",
        "to": "python/UseCurrency.py"
      },
      {
        "from": "python/LiftKeys.py",
        "to": "python/LiftKeys.py"
      },
         {
        "from": "Sounds/Sound1.wav",
        "to": "Sounds/Sound1.wav"
      }
    ],
    "win": {
      "target": "nsis",
      "electronLanguages": [
        "en-US"
      ],
      "icon": "frosttide23.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": true,
      "uninstallDisplayName": "Uninstall AutoReroll",
      "installerIcon": "frosttide23.ico",
      "allowElevation": true,
      "perMachine": true
    }
  },
  "files": [
    "main.js",
    "renderer/*",
    "python/*",
    "HelperFunctionsBackend/*",
    "HelperFunctionsFrontend/*"
  ],
  "scripts": {
    "start": "set NODE_ENV=Dev&&electron .",
    "pack": "set NODE_ENV=production && electron-builder --dir",
    "dist": "set NODE_ENV=production && electron-builder",
    "publish": "electron-builder --win -p always"
  },
  "author": "Frosttide",
  "license": "ISC",
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "electron-updater": "^6.6.2"
  }
}